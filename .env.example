# Root environment for docker-compose. Copy to .env at the repo root.
# The backend reads its own .env (see backend/.env.example); keep DATABASE_URL
# consistent between the two.

# Postgres container credentials (used by docker-compose.yml).
POSTGRES_USER=notion
POSTGRES_PASSWORD=notion
POSTGRES_DB=notion_clone
# Host port to expose Postgres on. Change if 5432 is in use on your machine.
POSTGRES_PORT=5432

# This is the DATABASE_URL the backend should use to reach the compose container.
# (Mirrored in backend/.env.example for convenience.)
DATABASE_URL=postgresql://notion:notion@localhost:5432/notion_clone
