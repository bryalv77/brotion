# Backend environment — copy to .env and adjust.
# The root .env.example has a matching DATABASE_URL for the docker-compose setup.

NODE_ENV=development
PORT=4000

# Postgres connection. With docker-compose (yarn db:up) use the port mapped in
# docker-compose.yml (default 5432); e.g.:
DATABASE_URL=postgresql://notion:notion@localhost:5432/notion_clone

# Frontend origin (CORS + cookie scope). Match Vite's port.
CLIENT_ORIGIN=http://localhost:5173

# JWT — generate real secrets for production (e.g. `openssl rand -hex 32`).
# Required from Task 2 onward; optional during setup so the server boots.
JWT_ACCESS_SECRET=replace_me_with_a_long_random_hex_string_min_32_chars
JWT_REFRESH_SECRET=replace_me_with_a_different_long_random_hex_string_min_32
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# Cookies: set to "true" in production (requires HTTPS).
COOKIE_SECURE=false

# Uploads
MAX_UPLOAD_BYTES=10485760

# Logging
LOG_LEVEL=info
